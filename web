        // Dropdown functionality
        function toggleDropdown(type) {
            const dropdown = document.getElementById(type + '-dropdown');
            const button = dropdown.previousElementSibling;
            
            document.querySelectorAll('.dropdown-options').forEach(dd => {
                if (dd.id !== type + '-dropdown') {
                    dd.classList.remove('show');
                    dd.previousElementSibling?.classList.remove('active');
                }
            });
            
            dropdown.classList.toggle('show');
            button.classList.toggle('active');
        }

        function updateSelected(type) {
            const dropdown = document.getElementById(type + '-dropdown');
            const selectedSpan = document.getElementById(type + '-selected');
            const checkboxes = dropdown.querySelectorAll('input[type="checkbox"]');
            
            const selected = Array.from(checkboxes)
                .filter(cb => cb.checked)
                .map(cb => cb.value);
            
            if (selected.length === 0) {
                selectedSpan.textContent = type === 'language' ? '請選擇語言能力' : '請選擇職位';
            } else if (selected.length === 1) {
                selectedSpan.textContent = selected[0];
            } else {
                selectedSpan.textContent = `已選擇 ${selected.length} 項`;
            }
            
            checkboxes.forEach(cb => {
                cb.closest('.dropdown-option').classList.toggle('selected', cb.checked);
            });
        }

        // File upload handling
        function getDefaultFileName(inputId) {
            const names = {
                'profile_photo': '點擊上傳證件相或大頭照 (JPG/PNG)',
                'hkid_copy': '點擊上傳身份證副本',
                'certificate_1': '點擊上傳證書一',
                'certificate_2': '證書二',
                'certificate_3': '證書三',
                'certificate_4': '證書四',
                'certificate_5': '證書五',
                'scrc_status': '點擊上傳 SCRC 文件'
            };
            return names[inputId] || '點擊上傳文件';
        }

        function validateFile(file, fieldName) {
            const maxSize = 10 * 1024 * 1024;
            if (file.size > maxSize) {
                throw new Error(`${fieldName}檔案太大，請選擇小於10MB的檔案`);
            }
            const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'application/pdf'];
            if (!allowedTypes.includes(file.type)) {
                throw new Error(`${fieldName}檔案格式不支援，請上傳 JPG、PNG 或 PDF 檔案`);
            }
        }

        // Event Listeners
        document.addEventListener('DOMContentLoaded', function() {
            // File inputs
            document.querySelectorAll('input[type="file"]').forEach(input => {
                input.addEventListener('change', function() {
                    const uploadDiv = this.parentElement;
                    const fileText = uploadDiv.querySelector('p');
                    
                    if (this.files[0]) {
                        const fileName = this.files[0].name;
                        const displayName = fileName.length > 25 ? fileName.substring(0, 25) + '...' : fileName;
                        fileText.textContent = `✓ ${displayName}`;
                        uploadDiv.classList.add('has-file');
                    } else {
                        fileText.textContent = getDefaultFileName(this.id);
                        uploadDiv.classList.remove('has-file');
                    }
                });
            });

            // Checkbox changes
            document.addEventListener('change', function(e) {
                if (e.target.type === 'checkbox' && e.target.closest('.dropdown-options')) {
                    const dropdown = e.target.closest('.dropdown-options');
                    if (dropdown.id === 'language-dropdown') updateSelected('language');
                    else if (dropdown.id === 'job_position-dropdown') updateSelected('job_position');
                }
            });

            // Click handler
            document.addEventListener('click', function(e) {
                const target = e.target;

                // File remove button
                const removeBtn = target.closest('.file-remove-btn');
                if (removeBtn) {
                    e.preventDefault();
                    e.stopPropagation();
                    const inputId = removeBtn.getAttribute('data-remove');
                    const input = document.getElementById(inputId);
                    if (input) {
                        input.value = '';
                        const uploadDiv = input.parentElement;
                        uploadDiv.querySelector('p').textContent = getDefaultFileName(inputId);
                        uploadDiv.classList.remove('has-file');
                    }
                    return;
                }

                // Dropdown option
                const optionRow = target.closest('.dropdown-option');
                if (optionRow && optionRow.closest('.dropdown-options')) {
                    const checkbox = optionRow.querySelector('input[type="checkbox"]');
                    if (checkbox && target !== checkbox && !target.closest('label')) {
                        checkbox.checked = !checkbox.checked;
                        checkbox.dispatchEvent(new Event('change', { bubbles: true }));
                    }
                    return;
                }

                // Dropdown toggle
                if (target.closest('.dropdown-options')) return;
                const selectButton = target.closest('.select-button');
                if (selectButton) {
                    e.preventDefault();
                    toggleDropdown(selectButton.getAttribute('data-dropdown'));
                    return;
                }

                // Close dropdowns when clicking outside
                if (!target.closest('.custom-select')) {
                    document.querySelectorAll('.dropdown-options').forEach(d => {
                        d.classList.remove('show');
                        d.previousElementSibling?.classList.remove('active');
                    });
                }
            }, true);
        });

