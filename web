        document.getElementById('nurseApplicationForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const submitBtn = document.getElementById('submit-btn');
            const statusMessage = document.getElementById('status-message');
            
            const contractStatus = document.getElementById('contract_status').value;
            if (contractStatus !== '同意') {
                alert('必須同意條款及細則才能提交申請');
                return;
            }

            statusMessage.innerHTML = '';
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="loading"></span> 提交中...';
            
            // Disable previous button during submission
            const prevBtn = document.querySelector('.btn-prev');
            if (prevBtn) prevBtn.disabled = true;
            
            try {
                updateStatus('正在連接伺服器...');
                
                const supabase = getSupabaseClient();
                if (!supabase) {
                    throw new Error('無法連接到資料庫');
                }

                updateStatus('正在提交個人資料...');

                const formData = new FormData(this);
                const languages = getSelectedLanguages();
                const jobPositions = getSelectedJobPositions();

                const submissionData = {
                    name_chinese: formData.get('name_chinese'),
                    name_english: formData.get('name_english'),
                    phone: formData.get('phone'),
                    email: formData.get('email') || null,
                    hkid: formData.get('hkid') || null,
                    dob: formData.get('dob') || null,
                    gender: formData.get('gender') || null,
                    nationality: formData.get('nationality') || null,
                    preferred_area: formData.get('preferred_area') || null,
                    address: formData.get('address') || null,
                    emergency_contact: formData.get('emergency_contact') || null,
                    emergency_contact_phone: formData.get('emergency_contact_phone') || null,
                    language: languages,
                    job_position: jobPositions,
                    experience_years: formData.get('experience_years') || null,
                    covid_vaccine: formData.get('covid_vaccine') || null,
                    referrer: formData.get('referrer') || null,
                    referrer_phone: formData.get('referrer_phone') || null,
                    company_name: formData.get('company_name') || null,
                    company_position: formData.get('company_position') || null,
                    employment_period: formData.get('employment_period') || null,
                    main_duties: formData.get('main_duties') || null,
                    contract_status: formData.get('contract_status'),
                    created_at: new Date().toISOString()
                };

                const { data: insertedData, error: insertError } = await supabase
                    .from('care_staff_profiles')
                    .insert([submissionData])
                    .select('id, staff_id');

                if (insertError) throw new Error(`資料庫錯誤: ${insertError.message}`);
                if (!insertedData || insertedData.length === 0) throw new Error('無法獲取新建記錄');

                const newRecord = insertedData[0];
                const staffId = newRecord.staff_id;

                updateStatus('正在上傳文件，請稍候...');

                // Upload files
                const fileFields = ['profile_photo', 'hkid_copy', 'certificate_1', 'certificate_2', 'certificate_3', 'certificate_4', 'certificate_5', 'scrc_status'];
                const fileUrls = {};
                const fieldMapping = {
                    'profile_photo': 'profile_photo_url',
                    'hkid_copy': 'hkid_copy_url',
                    'certificate_1': 'certificate_1',
                    'certificate_2': 'certificate_2',
                    'certificate_3': 'certificate_3',
                    'certificate_4': 'certificate_4',
                    'certificate_5': 'certificate_5',
                    'scrc_status': 'scrc_status'
                };

                const filesToUpload = fileFields.filter(f => document.getElementById(f)?.files[0]);
                let uploadedCount = 0;

                for (const fieldName of fileFields) {
                    const file = document.getElementById(fieldName)?.files[0];
                    if (file) {
                        uploadedCount++;
                        updateStatus(`正在上傳文件 (${uploadedCount}/${filesToUpload.length})...`);
                        
                        validateFile(file, fieldName);
                        const ext = file.name.split('.').pop();
                        const fileName = `${staffId}_${fieldName}_${Date.now()}.${ext}`;
