            let isValid = true;
            let errorMessage = '';

            if (step === 1) {
                const requiredFields = [
                    { id: 'name_chinese', label: '中文姓名' },
                    { id: 'name_english', label: '英文姓名' },
                    { id: 'phone', label: '電話號碼' },
                    { id: 'hkid', label: '香港身份證號碼' },
                    { id: 'dob', label: '出生日期' },
                    { id: 'gender', label: '性別' },
                    { id: 'nationality', label: '國籍' },
                    { id: 'address', label: '住址' },
                    { id: 'emergency_contact', label: '緊急聯絡人姓名' },
                    { id: 'emergency_contact_phone', label: '緊急聯絡人電話' }
                ];

                for (const field of requiredFields) {
                    const input = document.getElementById(field.id);
                    if (!input.value.trim()) {
                        isValid = false;
                        errorMessage = `請填寫${field.label}`;
                        input.classList.add('error');
                        input.focus();
                        break;
                    } else {
                        input.classList.remove('error');
                    }
                }
            }

            if (step === 2) {
                const languages = getSelectedLanguages();
                const jobPositions = getSelectedJobPositions();

                if (languages.length === 0) {
                    isValid = false;
                    errorMessage = '請至少選擇一種語言能力';
                } else if (jobPositions.length === 0) {
                    isValid = false;
                    errorMessage = '請至少選擇一個申請職位';
                }
            }

            if (step === 4) {
                const profilePhoto = document.getElementById('profile_photo').files[0];
                const hkidCopy = document.getElementById('hkid_copy').files[0];
                const cert1 = document.getElementById('certificate_1').files[0];

                if (!profilePhoto) {
                    isValid = false;
                    errorMessage = '請上傳個人照片（證件相或大頭照）';
                } else if (!hkidCopy) {
                    isValid = false;
                    errorMessage = '請上傳香港身份證副本';
                } else if (!cert1) {
                    isValid = false;
                    errorMessage = '請上傳證書一';
                }
            }

            if (!isValid) {
                alert(errorMessage);
            }

            return isValid;
        }

